---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gemmra — Nidāna for Pharmacovigilance',
  description = 'AI-powered drug safety review with auditable reasoning. Fine-tuned Gemma 4 31B for pharmacovigilance on AMD MI300X.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OpenGraph -->
    <meta property="og:title" content="Gemmra — Nidāna for Pharmacovigilance" />
    <meta property="og:description" content="AI-powered drug safety review with auditable reasoning. Fine-tuned Gemma 4 31B for pharmacovigilance on AMD MI300X." />
    <meta property="og:image" content="https://gemmra.bhaskarjha.dev/og-image.png" />
    <meta property="og:url" content="https://gemmra.bhaskarjha.dev" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Canonical -->
    <link rel="canonical" href="https://gemmra.bhaskarjha.dev" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <ClientRouter />
    
    <!-- JSON-LD Semantic Web -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Gemmra",
        "operatingSystem": "Linux, macOS, Windows",
        "applicationCategory": "HealthApplication",
        "softwareVersion": "1.0.0",
        "softwareRequirements": "AMD GPU / Web browser",
        "offers": {
          "@type": "Offer",
          "price": "0.00",
          "priceCurrency": "USD"
        },
        "description": "AI-powered drug safety review with auditable reasoning. Fine-tuned Gemma 4 31B for pharmacovigilance on AMD MI300X.",
        "url": "https://gemmra.bhaskarjha.dev",
        "downloadUrl": "https://gemmra.bhaskarjha.dev"
      }
    </script>

    <script defer data-domain="gemmra.bhaskarjha.dev" src="https://plausible.io/js/script.js"></script>
  </head>
  <body>
    <global-manager>
      <!-- Persistent Noise Overlay -->
      <div class="noise-overlay"></div>
      <slot />
    </global-manager>
    
    <script>
      class GlobalManager extends HTMLElement {
        private revealObserver: IntersectionObserver | null = null;
        
        private handleMousemove = (e: MouseEvent) => {
          const x = (e.clientX / window.innerWidth) * 100;
          const y = (e.clientY / window.innerHeight) * 100;
          document.body.style.setProperty('--mouse-x', `${x}%`);
          document.body.style.setProperty('--mouse-y', `${y}%`);
        };

        connectedCallback() {
          // Spotlight Logic
          document.addEventListener('mousemove', this.handleMousemove, { passive: true });

          // Global Reveal on Scroll
          const revealElements = this.querySelectorAll('.reveal');
          
          this.revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('active');
                // Optional: unobserve after revealing if you want it to trigger only once
              }
            });
          }, {
            root: null,
            threshold: 0.1,
            rootMargin: "0px 0px -50px 0px"
          });

          revealElements.forEach(el => this.revealObserver?.observe(el));
        }

        disconnectedCallback() {
          document.removeEventListener('mousemove', this.handleMousemove);
          if (this.revealObserver) {
            this.revealObserver.disconnect();
            this.revealObserver = null;
          }
        }
      }

      if (typeof window !== 'undefined' && !customElements.get('global-manager')) {
        customElements.define('global-manager', GlobalManager);
      }
    </script>
    <style>
      global-manager {
        display: contents; /* Does not affect layout flow */
      }
    </style>
  </body>
</html>
