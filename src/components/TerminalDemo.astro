---
import '@xterm/xterm/css/xterm.css';
---

<gemmra-terminal>
  <div class="terminal-window" aria-label="Interactive Terminal showing Gemmra inference">
    <div class="terminal-header">
      <div class="traffic-lights">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
      </div>
      <span class="terminal-title">gemmra — inference</span>
      
      <div class="terminal-modes">
        <button class="mode-btn active" id="mode-demo">Auto-Demo</button>
        <button class="mode-btn" id="mode-interactive">Interactive</button>
      </div>
    </div>
    
    <div class="terminal-body">
      <div id="terminal-container" style="height: 340px; width: 100%; position: relative;">
        <!-- Xterm.js will mount here -->
      </div>
    </div>
    
    <div class="terminal-hint" id="terminal-hint">
      Click terminal to take control
    </div>
  </div>
</gemmra-terminal>

<script>
  class GemmraTerminal extends HTMLElement {
    term: any = null;
    demoTimeout: any = null;
    processingInterval: any = null;
    abortController: AbortController | null = null;
    
    isAutoDemo = true;
    isDemoRunning = false;
    setupState = 'IDLE';
    currentLine = '';
    profileName = '';
    
    prompt = '\x1b[1;36mgemmra\x1b[0m \x1b[1;32m❯\x1b[0m ';

    connectedCallback() {
      // First Principle: Xterm.js strictly requires painted physical dimensions to boot.
      // We use a native ResizeObserver to deterministically wait until the browser 
      // has fully parsed the DOM and applied all CSS to the container.
      const container = this.querySelector('#terminal-container') as HTMLElement;
      if (!container) return;

      const observer = new ResizeObserver((entries) => {
        for (let entry of entries) {
          if (entry.contentRect.width > 0 && entry.contentRect.height > 0) {
            observer.disconnect(); // Stop observing once painted
            if (!this.abortController) { // Prevent double initialization
              this.setup(container);
            }
          }
        }
      });
      observer.observe(container);
    }

    setup(container: HTMLElement) {
      this.abortController = new AbortController();
      this.initTerminal(container).then(() => {
        if (this.isAutoDemo && !this.isDemoRunning) {
          this.runAutoDemo();
        }
      });
    }

    disconnectedCallback() {
      this.cleanup();
    }

    cleanup() {
      this.isAutoDemo = true;
      this.isDemoRunning = false;
      this.setupState = 'IDLE';
      this.currentLine = '';
      this.profileName = '';
      
      if (this.abortController) {
        this.abortController.abort();
        this.abortController = null;
      }

      if (this.demoTimeout) clearTimeout(this.demoTimeout);
      if (this.processingInterval) clearInterval(this.processingInterval);
      if (this.term) {
        this.term.dispose();
        this.term = null;
      }
      const container = this.querySelector('#terminal-container');
      if (container) container.innerHTML = '';
    }

    async initTerminal(container: HTMLElement) {
      const demoBtn = this.querySelector('#mode-demo') as HTMLElement;
      const interactiveBtn = this.querySelector('#mode-interactive') as HTMLElement;
      const hint = this.querySelector('#terminal-hint') as HTMLElement;
      
      this.cleanup();
      container.innerHTML = '';

      // Dynamic import to prevent bundle bloat (CSS is statically imported in frontmatter)
      const { Terminal } = await import('@xterm/xterm');

      this.term = new Terminal({
        cols: 70, // Fixed safe column count that fits the 600px container perfectly
        rows: 15,
        cursorBlink: true,
        fontFamily: 'monospace', // Start with fallback to prevent early texture corruption
        fontSize: 13,
        theme: {
          background: 'transparent',
          foreground: '#ededed',
          cursor: '#00c4cc',
          black: '#000000',
          red: '#ef4444',
          green: '#10b981',
          yellow: '#f59e0b',
          blue: '#0ea5e9',
          magenta: '#a1a1aa',
          cyan: '#00c4cc',
          white: '#ffffff'
        },
        allowTransparency: true,
        disableStdin: false
      });

      this.term.open(container);
      this.term.reset(); // Hard flush WebGL state
      this.term.clearTextureAtlas();

      // Dynamically upgrade font once loaded
      document.fonts.load('13px "JetBrains Mono"').then(() => {
        if (this.term) {
          this.term.options.fontFamily = '"JetBrains Mono", monospace';
          this.term.clearTextureAtlas();
        }
      }).catch(() => {});

      // --- HYBRID LOGIC ---

      demoBtn?.addEventListener('click', () => {
        if (this.isAutoDemo) return;
        this.isAutoDemo = true;
        this.isDemoRunning = false; // Reset lock
        
        demoBtn.classList.add('active');
        interactiveBtn.classList.remove('active');
        hint.style.opacity = '1';
        
        if (this.term) {
          this.term.reset();
          this.term.clearTextureAtlas();
        }
        
        this.setupState = 'IDLE';
        this.currentLine = '';
        this.profileName = '';
        
        if (this.demoTimeout) clearTimeout(this.demoTimeout);
        if (this.processingInterval) clearInterval(this.processingInterval);
        
        this.runAutoDemo();
      });

      interactiveBtn?.addEventListener('click', () => {
        if (!this.isAutoDemo) return;
        this.isAutoDemo = false; // The loops will check this and naturally exit!
        
        demoBtn.classList.remove('active');
        interactiveBtn.classList.add('active');
        hint.style.opacity = '0';
        
        if (this.processingInterval) clearInterval(this.processingInterval);
        
        if (this.term) {
          this.term.reset();
          this.term.clearTextureAtlas();
          this.term.write('\x1b[3mSandbox active. Try typing \x1b[33mgemmra analyze\x1b[0m\x1b[3m.\x1b[0m\r\n\r\n');
          this.term.write(this.prompt);
        }
      });

      container.addEventListener('click', () => {
        if (this.isAutoDemo) {
          interactiveBtn?.click();
        }
        if (this.term) this.term.focus();
      });

      // --- INTERACTIVE ENGINE ---

      this.term.onData(e => {
        if (this.isAutoDemo || !this.term) return; 

        if (e === '\x1b[A' || e === '\x1b[B' || e === '\x1b[C' || e === '\x1b[D') return;

        switch (e) {
          case '\r': // Enter
            this.term.write('\r\n');
            this.handleCommand(this.currentLine.trim());
            this.currentLine = '';
            break;
          case '\x7F': // Backspace
            if (this.currentLine.length > 0) {
              this.currentLine = this.currentLine.substring(0, this.currentLine.length - 1);
              this.term.write('\b \b');
            }
            break;
          case '\x03': // Ctrl+C
            this.term.write('^C\r\n');
            this.currentLine = '';
            this.setupState = 'IDLE';
            clearInterval(this.processingInterval);
            this.term.write(this.prompt);
            break;
          default:
            if (e >= String.fromCharCode(32) && e <= String.fromCharCode(126)) {
              this.currentLine += e;
              this.term.write(e);
            }
        }
      });
    }

    async wait(ms: number) {
      return new Promise((resolve, reject) => { 
        if (this.abortController?.signal.aborted) {
          return reject(new Error('Aborted'));
        }
        
        const onAbort = () => {
          clearTimeout(this.demoTimeout);
          reject(new Error('Aborted'));
        };
        
        this.abortController?.signal.addEventListener('abort', onAbort, { once: true });
        
        this.demoTimeout = setTimeout(() => {
          this.abortController?.signal.removeEventListener('abort', onAbort);
          if (!this.isAutoDemo) {
            reject(new Error('Demo stopped'));
          } else {
            resolve(true);
          }
        }, ms);
      }).catch(() => false);
    }

    async typeText(text: string, speed = 45) {
      for (let i = 0; i < text.length; i++) {
        if (!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) {
          this.isDemoRunning = false;
          return false;
        }
        this.term.write(text.charAt(i));
        const continued = await this.wait(speed);
        if (!continued) return false;
      }
      return true;
    }

    handleCommand(cmd: string) {
      if (!this.term) return;
      const cleanCmd = cmd.trim().toLowerCase();
      if (cleanCmd.startsWith('gemmra analyze')) {
        this.term.write('\r\n\x1b[1;33m[Case Context]\x1b[0m\r\n');
        this.term.write('  Patient: 68-year-old male on Warfarin 5mg daily for AFib\r\n');
        this.term.write('  Event: GI haemorrhage | Outcome: Hospitalized\r\n\r\n');
        this.term.write('\x1b[36mAnalyzing case against ICH E2A seriousness criteria...\x1b[0m\r\n\r\n');
        this.term.write('\x1b[2m<thinking>\x1b[0m\r\n');
        this.term.write('  → Outcome "Hospitalized" maps to HO (Hospitalization)\r\n');
        this.term.write('  → GI haemorrhage is a known serious AE for anticoagulants\r\n');
        this.term.write('  → Warfarin is a high-risk narrow therapeutic index drug\r\n');
        this.term.write('  Assessment: \x1b[1;31mSERIOUS\x1b[0m — criterion HO met\r\n');
        this.term.write('\x1b[2m</thinking>\x1b[0m\r\n\r\n');
        this.term.write('\x1b[1;32mSERIOUS:\x1b[0m YES\r\n');
        this.term.write('\x1b[1;32mCRITERIA:\x1b[0m HO\r\n');
        this.term.write('\x1b[1;32mRATIONALE:\x1b[0m Patient hospitalized for GI haemorrhage,\r\n');
        this.term.write('           a known serious adverse event for Warfarin therapy.\r\n\r\n');
        this.term.write(this.prompt);
      } else if (cleanCmd === 'clear') {
        this.term.reset();
        this.term.write(this.prompt);
      } else if (cleanCmd === 'help') {
        this.term.write('Available commands:\r\n');
        this.term.write('  \x1b[33mgemmra analyze\x1b[0m - Run AI safety analysis on current case\r\n');
        this.term.write('  \x1b[33mclear\x1b[0m          - Clear the terminal screen\r\n');
        this.term.write('  \x1b[33mhelp\x1b[0m           - Show this help message\r\n\r\n');
        this.term.write(this.prompt);
      } else if (cleanCmd !== '') {
        this.term.write(`\x1b[31mcommand not found:\x1b[0m ${cmd}\r\n`);
        this.term.write('Type \x1b[33mhelp\x1b[0m to see available commands.\r\n\r\n');
        this.term.write(this.prompt);
      } else {
        this.term.write(this.prompt);
      }
    }

    async runAutoDemo() {
      if (this.isDemoRunning || !this.isAutoDemo || !this.term || this.abortController?.signal.aborted) return;
      this.isDemoRunning = true;
      this.term.write(this.prompt);
      
      await this.wait(1000);
      
      if (!(await this.typeText('gemmra analyze --case-id case_0892', 50))) return;
      
      await this.wait(600);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('\r\n\r\n\x1b[1;33m[Case Context]\x1b[0m\r\n');
      this.term.write('  Patient: 68-year-old male on Warfarin 5mg daily for AFib\r\n');
      this.term.write('  Event: GI haemorrhage | Outcome: Hospitalized\r\n\r\n');
      
      await this.wait(800);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('\x1b[36mAnalyzing case against ICH E2A seriousness criteria\x1b[0m');
      
      for(let i = 0; i < 3; i++) {
        await this.wait(400);
        if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
        this.term.write('.');
      }
      
      await this.wait(400);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('\r\n\r\n\x1b[2m<thinking>\x1b[0m\r\n');
      
      await this.wait(500);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('  → Outcome "Hospitalized" maps to HO (Hospitalization)\r\n');
      
      await this.wait(500);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('  → GI haemorrhage is a known serious AE for anticoagulants\r\n');
      
      await this.wait(500);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('  → Warfarin is a high-risk narrow therapeutic index drug\r\n');
      
      await this.wait(500);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('  Assessment: \x1b[1;31mSERIOUS\x1b[0m — criterion HO met\r\n');
      
      await this.wait(400);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('\x1b[2m</thinking>\x1b[0m\r\n\r\n');
      
      await this.wait(600);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write('\x1b[1;32mSERIOUS:\x1b[0m YES\r\n');
      this.term.write('\x1b[1;32mCRITERIA:\x1b[0m HO\r\n');
      this.term.write('\x1b[1;32mRATIONALE:\x1b[0m Patient hospitalized for GI haemorrhage,\r\n');
      this.term.write('           a known serious adverse event for Warfarin therapy.\r\n\r\n');
      
      await this.wait(1000);
      if(!this.isAutoDemo || !this.term || this.abortController?.signal.aborted) { this.isDemoRunning = false; return; }
      this.term.write(this.prompt);
      this.isDemoRunning = false;
    }
  }

  // Register the custom element once
  if (typeof window !== 'undefined' && !customElements.get('gemmra-terminal')) {
    customElements.define('gemmra-terminal', GemmraTerminal);
  }
</script>

<style>
  .terminal-window {
    width: 100%;
    margin: 0 auto;
    background: rgba(5, 5, 5, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 1), 0 0 0 1px rgba(255, 255, 255, 0.03), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    position: relative;
    text-align: left; /* Fix inherited text-align: center from Hero.astro on mobile */
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--border-subtle);
  }

  .traffic-lights {
    position: absolute;
    left: 16px;
    display: flex;
    gap: 8px;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.yellow { background: #f59e0b; }
  .terminal-dot.green { background: #10b981; }

  .terminal-title {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .terminal-modes {
    position: absolute;
    right: 16px;
    display: flex;
    gap: 4px;
    background: rgba(255,255,255,0.05);
    padding: 2px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .mode-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 10px;
    font-family: var(--font-sans);
    padding: 4px 8px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mode-btn:hover {
    color: var(--text-primary);
  }

  .mode-btn.active {
    background: rgba(255,255,255,0.1);
    color: var(--text-primary);
  }

  .terminal-body {
    padding: var(--space-md);
    background: transparent;
    cursor: text;
    overflow-x: auto; /* Handle fixed 70 cols on small screens safely */
    scrollbar-width: none; /* Hide scrollbar for cleaner UI */
  }
  
  .terminal-body::-webkit-scrollbar {
    display: none;
  }

  .terminal-hint {
    position: absolute;
    bottom: 16px;
    right: 16px;
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(0, 0, 0, 0.6);
    padding: 4px 8px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .terminal-window:focus-within .terminal-hint {
    opacity: 0;
  }

  /* Xterm CSS Overrides to match theme */
  :global(.xterm-viewport) {
    background-color: transparent !important;
    overflow: hidden !important; /* Force prevent rogue scrollbars */
  }
  
  :global(.xterm-screen) {
    padding-left: 8px;
  }

  /* Mobile Flaw Fixes */
  @media (max-width: 600px) {
    .terminal-title {
      display: none; /* Prevent overlap with mode buttons */
    }
    
    .terminal-modes {
      position: static; /* Re-center mode buttons naturally */
      margin-left: auto;
    }
    
    .traffic-lights {
      position: relative;
      left: 0;
    }
    
    .terminal-header {
      justify-content: flex-start;
      gap: var(--space-md);
    }
  }
</style>
