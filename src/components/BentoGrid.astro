---
---

<section class="bento-section section reveal" id="architecture">
  <div class="bento-container container">
    <div class="bento-header reveal delay-100">
      <h2 class="section-title">Engineered on <span class="accent-text">AMD MI300X.</span></h2>
      <p class="section-subtitle">Full bf16 precision, zero quantization, LoRA r=64. Every architectural choice leverages AMD's 192 GB HBM3 advantage.</p>
    </div>

    <div class="bento-grid">
      
      <!-- Card 1: bf16 LoRA (2x2) -->
      <div class="bento-card span-2x2 reveal delay-200 card-1">
        <div class="bento-visual card-1-visual">
          <div class="svg-flow-container">
            <svg class="flow-lines" viewBox="0 0 100 100" preserveAspectRatio="none">
              <path class="animated-path" d="M0 50 Q 25 20, 50 50 T 100 50" fill="none" stroke="currentColor" stroke-width="2" />
            </svg>
            <div class="lock-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3>bf16 LoRA Training</h3>
          <p>Full bf16 precision with LoRA rank 64 on MI300X. Zero quantization = zero gradient noise. <code>LoRA r=64</code></p>
        </div>
      </div>

      <!-- Card 2: Thinking Mode (1x1) -->
      <div class="bento-card span-1x1 reveal delay-300">
        <div class="bento-visual icon-visual">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="accent-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <div class="bento-content">
          <h3>Extended Thinking Mode</h3>
          <p>Gemma 4's native thinking mode generates visible reasoning traces — the audit trail regulators require. <code>enable_thinking=True</code></p>
        </div>
      </div>

      <!-- Card 3: Data-First Debugging (1x1) -->
      <div class="bento-card span-1x1 reveal delay-400">
        <div class="bento-visual icon-visual">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="accent-icon"><path d="M12 22c5.523 0 10-2.239 10-5V5c0-2.761-4.477-5-10-5S2 2.239 2 5v12c0 2.761 4.477 5 10 5z"/><path d="M22 5c0 2.761-4.477 5-10 5S2 7.761 2 5"/><path d="M22 11c0 2.761-4.477 5-10 5S2 13.761 2 11"/></svg>
        </div>
        <div class="bento-content">
          <h3>Data-First Debugging</h3>
          <p>Our biggest gain came from fixing one data pipeline bug, not hyperparameter tuning. Data quality &gt; model tricks. <code>3.9× improvement</code></p>
        </div>
      </div>

      <!-- Card 4: Hierarchical Evaluation (2x1) -->
      <div class="bento-card span-2x1 reveal delay-200">
        <div class="bento-visual hierarchy-visual">
          <div class="hierarchy-bars">
            <div class="hierarchy-bar-row">
              <span class="bar-label">Exact Match</span>
              <div class="bar-track"><div class="bar-fill exact" style="width: 100%;"></div></div>
            </div>
            <div class="hierarchy-bar-row">
              <span class="bar-label">Synonym Match</span>
              <div class="bar-track"><div class="bar-fill synonym" style="width: 85%;"></div></div>
            </div>
            <div class="hierarchy-bar-row">
              <span class="bar-label">Fuzzy Match</span>
              <div class="bar-track"><div class="bar-fill fuzzy" style="width: 60%;"></div></div>
            </div>
            <div class="hierarchy-bar-row">
              <span class="bar-label">SOC Match</span>
              <div class="bar-track"><div class="bar-fill soc" style="width: 40%;"></div></div>
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3>Hierarchical Evaluation</h3>
          <p>Novel 4-level scoring: exact → synonym → fuzzy → SOC match. 3,645 decontaminated evaluation samples. <code>Gemmra-Bench</code></p>
        </div>
      </div>

      <!-- Card 5: FAERS Pipeline (1x1) -->
      <div class="bento-card span-1x1 reveal delay-300">
        <div class="bento-visual icon-visual-large" style="min-height: 120px;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.8; filter: drop-shadow(0 0 10px rgba(34, 197, 94, 0.4));">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <div class="bento-content">
          <h3>FAERS Pipeline</h3>
          <p>Automated ingestion of 29 quarters of FDA adverse event data (2019Q1–2026Q1) via DuckDB. <code>29 quarters</code></p>
        </div>
      </div>

      <!-- Card 6: Published Negative Results (3x1) -->
      <div class="bento-card span-3x1 reveal delay-400">
        <div class="vault-bg">
          <svg viewBox="0 0 100 100" class="vault-mesh" preserveAspectRatio="none">
            <!-- Background Grid -->
            <pattern id="grid-pattern" width="8" height="8" patternUnits="userSpaceOnUse">
              <path d="M 8 0 L 0 0 0 8" fill="none" stroke="rgba(255, 255, 255, 0.02)" stroke-width="0.5"/>
            </pattern>
            <rect width="100" height="100" fill="url(#grid-pattern)" />
            
            <!-- Server Racks / Data Blocks -->
            <g stroke="rgba(255, 255, 255, 0.1)" stroke-width="0.5" fill="none">
              <rect x="20" y="20" width="60" height="15" rx="2" />
              <rect x="20" y="42.5" width="60" height="15" rx="2" stroke="rgba(255, 255, 255, 0.2)" />
              <rect x="20" y="65" width="60" height="15" rx="2" />
              
              <!-- Status Lights -->
              <circle cx="25" cy="27.5" r="1.5" fill="rgba(255, 255, 255, 0.2)" stroke="none" />
              <circle cx="25" cy="50" r="1.5" fill="rgba(255, 255, 255, 0.6)" stroke="none" />
              <circle cx="25" cy="72.5" r="1.5" fill="rgba(255, 255, 255, 0.2)" stroke="none" />
              
              <!-- Encrypted Data Lines -->
              <line x1="30" y1="27.5" x2="70" y2="27.5" stroke-dasharray="2 2" />
              <line x1="30" y1="50" x2="75" y2="50" stroke-dasharray="2 2" stroke="rgba(255, 255, 255, 0.3)" />
              <line x1="30" y1="72.5" x2="60" y2="72.5" stroke-dasharray="2 2" />
            </g>
          </svg>
        </div>
        <div class="bento-content">
          <div class="text-group" style="max-width: 60%;">
            <h3>Published Negative Results</h3>
            <p>We documented what didn't work — and proved why. RL on pure SFT collapsed; RL on WiSE-FT gained +0.003 then hit the same ceiling. SFT captured all learnable signal. <code>Scientific Rigor</code></p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // Spotlights
    const cards = document.querySelectorAll('.bento-card');
    cards.forEach(card => {
      card.addEventListener('mousemove', (e: any) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        (card as HTMLElement).style.setProperty('--spotlight-x', `${x}px`);
        (card as HTMLElement).style.setProperty('--spotlight-y', `${y}px`);
      });
    });
  });
</script>

<style>
  .bento-header {
    margin-bottom: var(--space-4xl);
  }

  .bento-container {
    width: 100%;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(220px, auto);
    grid-auto-flow: dense;
    gap: var(--space-md);
    max-width: 1100px;
    margin: 0 auto;
  }

  .bento-card {
    background: transparent;
    border: 1px solid var(--border-card);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  /* Magic Borders */
  @keyframes borderSpin {
    100% { transform: rotate(360deg); }
  }

  .bento-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(transparent, transparent, transparent, var(--accent-secondary), var(--border-accent), var(--accent-primary));
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: -1;
  }

  .bento-card::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: calc(var(--radius-xl) - 1px);
    background-color: var(--bg-secondary);
    background-image: radial-gradient(circle at var(--spotlight-x, 50%) var(--spotlight-y, 50%), rgba(99, 102, 241, 0.05) 0%, transparent 500px);
    z-index: -1;
    transition: background-color var(--transition-base), background-image 0s;
  }

  .bento-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(99, 102, 241, 0.08);
  }

  .bento-card:hover::before {
    opacity: 1;
    animation: borderSpin 4s linear infinite;
  }

  .bento-card:hover::after {
    background-color: var(--bg-tertiary);
    background-image: radial-gradient(circle at var(--spotlight-x, 50%) var(--spotlight-y, 50%), rgba(99, 102, 241, 0.08) 0%, transparent 600px);
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* Grid Spanning */
  .span-2x2 { grid-column: span 2; grid-row: span 2; }
  .span-2x1 { grid-column: span 2; grid-row: span 1; }
  .span-1x1 { grid-column: span 1; grid-row: span 1; }
  .span-3x1 { grid-column: span 3; grid-row: span 1; }

  /* Content Inner */
  .bento-content {
    padding: var(--space-lg) var(--space-xl);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    z-index: 2;
  }

  .bento-content h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
    color: var(--text-heading);
  }

  .bento-content p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .bento-content code {
    background: var(--bg-code);
    color: var(--accent-primary);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    border: 1px solid var(--border-subtle);
  }

  /* Visuals Area */
  .bento-visual {
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.01);
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
    overflow: hidden;
    z-index: 0;
  }

  /* Card 1 Visual: Lock & Flow */
  .card-1 .bento-content {
    justify-content: center;
    align-items: flex-start;
    padding: var(--space-2xl) var(--space-xl);
    width: 55%;
    position: relative;
    z-index: 2;
  }

  .card-1 h3 {
    font-size: var(--text-3xl);
    max-width: 100%;
  }

  .card-1 p {
    font-size: var(--text-lg);
    max-width: 100%;
  }

  .card-1-visual {
    position: absolute;
    inset: 0 0 0 auto;
    width: 45%;
    height: 100%;
    opacity: 1;
    z-index: 1;
    border: none;
    border-left: 1px solid var(--border-subtle);
    background: radial-gradient(circle at center, rgba(0, 196, 204, 0.05) 0%, transparent 70%);
  }
  
  .svg-flow-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow-lines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    color: var(--accent-glow-strong);
  }

  .animated-path {
    stroke-dasharray: 10 10;
    animation: flowDash 15s linear infinite;
  }

  @keyframes flowDash {
    to { stroke-dashoffset: -200; }
  }
  
  .lock-icon {
    position: relative;
    color: var(--text-primary);
    z-index: 2;
    background: var(--bg-code);
    padding: var(--space-md);
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.05), inset 0 0 10px rgba(255, 255, 255, 0.05);
  }

  .icon-visual-large {
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* Hierarchy Visual Chart */
  .hierarchy-visual {
    min-height: 140px;
    background: rgba(255,255,255,0.01);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) var(--space-xl);
    width: 100%;
    border-bottom: 1px solid var(--border-subtle);
  }
  .hierarchy-bars {
    width: 100%;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hierarchy-bar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .bar-label {
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    min-width: 90px;
    text-align: right;
  }
  .bar-track {
    flex-grow: 1;
    height: 5px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: var(--radius-full);
  }
  .bar-fill.exact {
    background: var(--accent-primary);
    box-shadow: 0 0 10px rgba(237, 28, 36, 0.3);
  }
  .bar-fill.synonym {
    background: #6366f1;
    box-shadow: 0 0 10px rgba(99, 102, 241, 0.3);
  }
  .bar-fill.fuzzy {
    background: var(--accent-secondary);
    box-shadow: 0 0 10px rgba(15, 98, 254, 0.3);
  }
  .bar-fill.soc {
    background: var(--text-muted);
  }

  /* Metric Visual */
  .metric-visual {
    min-height: 120px;
  }
  .metric-value {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--text-heading);
    letter-spacing: -0.05em;
  }
  .metric-unit {
    font-size: 1.5rem;
    color: var(--accent-primary);
  }

  /* Icon Visual */
  .icon-visual {
    min-height: 120px;
  }
  .accent-icon {
    color: var(--accent-primary);
    width: 48px;
    height: 48px;
  }

  /* Removed rotation CSS */

  /* Standard Media Queries for predictable layout */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
    }
    .span-2x2, .span-3x1 {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .span-2x2, .span-2x1, .span-3x1, .span-1x1 {
      grid-column: span 1;
    }
    .text-group {
      max-width: 100% !important;
    }
    .card-1 .bento-content {
      width: 100%;
      padding-bottom: 180px;
    }
    .card-1-visual {
      inset: auto 0 0 0;
      width: 100%;
      height: 160px;
      border-left: none;
      border-top: 1px solid var(--border-subtle);
    }
  }

  /* Vault Effect */
  .vault-bg {
    position: absolute; inset: 0; overflow: hidden; z-index: 0; pointer-events: none;
    mask-image: radial-gradient(circle at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(circle at center, black 0%, transparent 70%);
  }
  .vault-mesh {
    width: 100%; height: 100%;
  }
</style>
