---
---

<command-palette>
  <div id="command-palette-backdrop" class="cmd-backdrop" aria-hidden="true">
  <div class="cmd-modal" role="dialog" aria-modal="true" aria-label="Command Palette">
    <div class="cmd-header">
      <svg class="cmd-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="cmd-input" class="cmd-input" role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="dynamic-search-results" placeholder="Search documentation, commands, and settings..." autocomplete="off" spellcheck="false" />
      <button id="cmd-close" class="cmd-close" aria-label="Close">ESC</button>
    </div>
    <div class="cmd-body">
      <!-- Dynamic Search Results -->
      <div class="cmd-section" id="dynamic-search-section" style="display: none;">
        <ul class="cmd-results" id="dynamic-search-results" role="listbox">
          <!-- Injected via JS -->
        </ul>
      </div>

      <div class="cmd-section default-section">
        <div class="cmd-section-title">Quick Links</div>
        <ul class="cmd-results" role="listbox">
          <li>
            <a href="/docs/getting-started/quickstart" class="cmd-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
              <span>Quickstart Guide</span>
              <kbd class="cmd-shortcut">⏎</kbd>
            </a>
          </li>
          <li>
            <a href="/docs/core-engines/identity-routing" class="cmd-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
              <span>Identity Routing Architecture</span>
            </a>
          </li>
          <li>
            <a href="/docs/guides/hardware-keys" class="cmd-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
              <span>Configure FIDO2 Hardware Keys</span>
            </a>
          </li>
        </ul>
      </div>
      
      <div class="cmd-section default-section">
        <div class="cmd-section-title">Actions</div>
        <ul class="cmd-results" role="listbox">
          <li>
            <button class="cmd-item" onclick="navigator.clipboard.writeText('curl -sL https://gitsetu.bhaskarjha.dev/install | bash'); alert('Install command copied!')">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              <span>Copy Install Command</span>
            </button>
          </li>
        </ul>
      </div>
    </div>
    <div class="cmd-footer">
      <span><kbd>↑</kbd> <kbd>↓</kbd> to navigate</span>
      <span><kbd>⏎</kbd> to select</span>
      <span><kbd>ESC</kbd> to close</span>
    </div>
  </div>
  <div id="cmd-announcer" aria-live="polite" style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;"></div>
</command-palette>
<script>
  class CommandPalette extends HTMLElement {
    private oramaDb: any = null;
    private isFetching = false;
    private backdrop: HTMLElement | null;
    private input: HTMLInputElement | null;
    private closeBtn: HTMLElement | null;
    private defaultSections: NodeListOf<HTMLElement>;
    private dynamicSection: HTMLElement | null;
    private dynamicResults: HTMLElement | null;
    private selectedIndex = -1;
    private debounceTimer: number | null = null;
    
    private handleKeydown: (e: KeyboardEvent) => void;
    private handleGlobalOpen: (e: Event) => void;
    private handleGlobalKeydown: (e: KeyboardEvent) => void;

    constructor() {
      super();
      this.backdrop = this.querySelector('.cmd-backdrop');
      this.input = this.querySelector('#cmd-input');
      this.closeBtn = this.querySelector('#cmd-close');
      this.defaultSections = this.querySelectorAll('.default-section');
      this.dynamicSection = this.querySelector('#dynamic-search-section');
      this.dynamicResults = this.querySelector('#dynamic-search-results');

      this.handleKeydown = this.onKeydown.bind(this);
      this.handleGlobalOpen = this.openPalette.bind(this);
      this.handleGlobalKeydown = this.onGlobalKeydown.bind(this);
    }

    connectedCallback() {
      this.backdrop?.addEventListener('click', (e) => {
        if (e.target === this.backdrop) this.closePalette();
      });
      this.closeBtn?.addEventListener('click', () => this.closePalette());
      this.input?.addEventListener('input', (e) => this.onInput(e));

      document.addEventListener('open-command-palette', this.handleGlobalOpen);
      document.addEventListener('keydown', this.handleGlobalKeydown);
      
      // Initialize IDs for default options
      let optionIndex = 0;
      this.defaultSections.forEach(section => {
        section.querySelectorAll('li').forEach(li => {
          li.setAttribute('role', 'option');
          li.setAttribute('id', `cmd-opt-default-${optionIndex++}`);
        });
      });
    }

    disconnectedCallback() {
      document.removeEventListener('open-command-palette', this.handleGlobalOpen);
      document.removeEventListener('keydown', this.handleGlobalKeydown);
    }

    async fetchSearchIndex() {
      if (this.oramaDb || this.isFetching) return;
      this.isFetching = true;
      try {
        const res = await fetch('/search.json');
        if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
        const data = await res.json();
        
        const { create, insertMultiple } = await import('@orama/orama');
        
        this.oramaDb = await create({
          schema: {
            title: 'string',
            description: 'string',
            content: 'string',
            url: 'string'
          }
        });

        await insertMultiple(this.oramaDb, data);
      } catch (e: any) {
        console.error('Failed to fetch search index:', e);
        if (this.dynamicResults) {
          this.dynamicResults.innerHTML = `<li role="option" style="padding: 12px; color: #ff5f56;">Failed to load search index</li>`;
        }
      } finally {
        this.isFetching = false;
      }
    }

    openPalette() {
      this.fetchSearchIndex();
      this.backdrop?.classList.add('active');
      document.body.style.overflow = 'hidden';
      this.selectedIndex = -1;
      
      this.input?.setAttribute('aria-expanded', 'true');
      
      setTimeout(() => {
        if (this.input) {
          this.input.value = '';
          this.input.dispatchEvent(new Event('input'));
          this.input.focus();
        }
      }, 100);

      document.addEventListener('keydown', this.handleKeydown);
    }

    closePalette() {
      this.backdrop?.classList.remove('active');
      document.body.style.overflow = '';
      this.selectedIndex = -1;
      
      this.input?.setAttribute('aria-expanded', 'false');
      this.input?.removeAttribute('aria-activedescendant');
      this.input?.blur();

      document.removeEventListener('keydown', this.handleKeydown);
      
      const trigger = document.getElementById('search-btn');
      if (trigger) trigger.focus();
    }

    onGlobalKeydown(e: KeyboardEvent) {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        this.openPalette();
      }
    }

    onKeydown(e: KeyboardEvent) {
      if (!this.backdrop?.classList.contains('active')) return;
      
      if (e.key === 'Escape') {
        this.closePalette();
        return;
      }

      if (e.key === 'Tab') {
        const focusable = Array.from(this.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])')) as HTMLElement[];
        const visibleFocusable = focusable.filter(el => {
          const style = window.getComputedStyle(el);
          return style.display !== 'none' && style.visibility !== 'hidden' && el.offsetWidth > 0;
        });
        
        if (visibleFocusable.length === 0) {
          e.preventDefault();
          return;
        }
        
        const firstElement = visibleFocusable[0];
        const lastElement = visibleFocusable[visibleFocusable.length - 1];

        if (e.shiftKey && document.activeElement === firstElement) {
          e.preventDefault();
          lastElement.focus();
        } else if (!e.shiftKey && document.activeElement === lastElement) {
          e.preventDefault();
          firstElement.focus();
        }
        return;
      }

      const items = this.dynamicSection?.style.display === 'none' 
        ? Array.from(this.querySelectorAll('.default-section:not([style*="display: none"]) li:not([style*="display: none"]) .cmd-item'))
        : Array.from(this.querySelectorAll('#dynamic-search-results .cmd-item'));

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (items.length > 0) {
          this.selectedIndex = (this.selectedIndex + 1) % items.length;
          this.updateSelection(items);
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (items.length > 0) {
          this.selectedIndex = (this.selectedIndex - 1 + items.length) % items.length;
          this.updateSelection(items);
        }
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (this.selectedIndex >= 0 && this.selectedIndex < items.length) {
          (items[this.selectedIndex] as HTMLElement).click();
        } else if (items.length > 0) {
          (items[0] as HTMLElement).click();
        }
      }
    }

    updateSelection(items: Element[]) {
      items.forEach((item, index) => {
        const li = item.closest('li');
        if (index === this.selectedIndex) {
          item.classList.add('selected');
          if (li) {
            li.setAttribute('aria-selected', 'true');
            const id = li.getAttribute('id');
            if (id) this.input?.setAttribute('aria-activedescendant', id);
          }
          (item as HTMLElement).scrollIntoView({ block: 'nearest' });
        } else {
          item.classList.remove('selected');
          if (li) li.setAttribute('aria-selected', 'false');
        }
      });
    }

    onInput(e: Event) {
      if (this.debounceTimer) window.clearTimeout(this.debounceTimer);
      
      this.debounceTimer = window.setTimeout(async () => {
        const query = (e.target as HTMLInputElement).value.trim();
        
        if (query.length > 0) {
          this.defaultSections.forEach(sec => (sec as HTMLElement).style.display = 'none');
          
          if (this.dynamicSection && this.dynamicResults) {
            this.dynamicSection.style.display = '';
            let html = '';
            
            if (!this.oramaDb) {
               this.dynamicResults.innerHTML = `<li role="option" style="padding: 12px 16px; color: var(--text-muted); font-size: 12px;">Initializing search engine...</li>`;
               return;
            }

            const { search } = await import('@orama/orama');
            const searchResult = await search(this.oramaDb, {
              term: query,
              properties: '*',
              tolerance: 1,
              limit: 15
            });

            const titleMatches: Array<any> = [];
            const contentMatches: Array<any> = [];
            
            searchResult.hits.forEach(hit => {
              const doc = hit.document;
              if (doc.title.toLowerCase().includes(query.toLowerCase()) || doc.url.toLowerCase().includes(query.toLowerCase())) {
                titleMatches.push(doc);
              } else {
                contentMatches.push(doc);
              }
            });

            const commandMatches: Array<string> = [];
            this.defaultSections.forEach(sec => {
              const items = sec.querySelectorAll('.cmd-item');
              items.forEach(item => {
                if (item.textContent?.toLowerCase().includes(query.toLowerCase())) {
                  commandMatches.push(item.parentElement?.innerHTML || '');
                }
              });
            });

            let optionIndex = 0;

            if (titleMatches.length > 0) {
              html += '<div class="cmd-section-title" style="margin-top: 12px;" role="presentation">Documentation</div>';
              html += titleMatches.map(item => `
                <li role="option" id="cmd-opt-${optionIndex++}">
                  <a href="${item.url}" class="cmd-item" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                      <span>${item.title}</span>
                      ${item.description ? `<span style="font-size: 10px; opacity: 0.6;">${item.description}</span>` : ''}
                    </div>
                  </a>
                </li>
              `).join('');
            }

            if (commandMatches.length > 0) {
              html += '<div class="cmd-section-title" style="margin-top: 12px;" role="presentation">Commands</div>';
              html += commandMatches.map(cmdHtml => `<li role="option" id="cmd-opt-${optionIndex++}">${cmdHtml.replace('class="cmd-item"', 'class="cmd-item" tabindex="-1"')}</li>`).join('');
            }

            if (contentMatches.length > 0) {
              html += '<div class="cmd-section-title" style="margin-top: 12px;" role="presentation">Text Mentions</div>';
              html += contentMatches.map(item => `
                <li role="option" id="cmd-opt-${optionIndex++}">
                  <a href="${item.url}" class="cmd-item" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                      <span>${item.title}</span>
                      <span style="font-size: 10px; opacity: 0.6; color: var(--accent-primary);">Match found in contents</span>
                    </div>
                  </a>
                </li>
              `).join('');
            }

            if (html === '') {
              html = `
                <li role="option" style="padding: 12px 16px; color: var(--text-muted); font-size: 12px;">
                  No results found for "${query}".
                </li>
              `;
            }

            this.dynamicResults.innerHTML = html;
            
            const announcer = document.getElementById('cmd-announcer');
            if (announcer) {
              const numResults = this.dynamicResults.querySelectorAll('[role="option"]').length;
              announcer.textContent = `${numResults} results available. Use up and down arrows to review.`;
            }
            this.selectedIndex = -1;
          }
        } else {
          this.defaultSections.forEach(sec => (sec as HTMLElement).style.display = '');
          if (this.dynamicSection) this.dynamicSection.style.display = 'none';
          
          this.defaultSections.forEach(section => {
            const items = section.querySelectorAll('.cmd-item');
            let hasVisibleItem = false;
            items.forEach(item => {
              const text = item.textContent?.toLowerCase() || '';
              const li = item.closest('li');
              if (text.includes(query)) {
                if (li) li.style.display = '';
                hasVisibleItem = true;
              } else {
                if (li) li.style.display = 'none';
              }
            });
            (section as HTMLElement).style.display = hasVisibleItem ? '' : 'none';
          });
          this.selectedIndex = -1;
        }
      }, 150);
    }
  }

  if (!customElements.get('command-palette')) {
    customElements.define('command-palette', CommandPalette);
  }
</script>

<style is:global>
  .cmd-backdrop {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-fast);
  }

  .cmd-backdrop.active {
    opacity: 1;
    pointer-events: auto;
  }

  .cmd-modal {
    width: 100%;
    max-width: 600px;
    background: rgba(10, 10, 10, 0.95);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-xl);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 255, 255, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    overflow: hidden;
    transform: scale(0.98) translateY(-10px);
    transition: transform var(--transition-fast);
  }

  .cmd-backdrop.active .cmd-modal {
    transform: scale(1) translateY(0);
  }

  .cmd-header {
    display: flex;
    align-items: center;
    padding: 0 var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.02);
  }

  .cmd-search-icon {
    color: var(--accent-primary);
    margin-right: var(--space-sm);
  }

  .cmd-input {
    flex-grow: 1;
    background: transparent;
    border: none;
    color: var(--text-heading);
    font-size: var(--text-lg);
    padding: var(--space-lg) 0;
    outline: none;
    font-family: var(--font-sans);
  }

  .cmd-input::placeholder {
    color: var(--text-muted);
  }

  .cmd-close {
    background: var(--bg-code);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-family: var(--font-mono);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .cmd-close:hover {
    color: var(--text-heading);
    border-color: var(--text-secondary);
  }

  .cmd-body {
    padding: var(--space-md) var(--space-lg);
    max-height: 400px;
    overflow-y: auto;
  }

  .cmd-section {
    margin-bottom: var(--space-lg);
  }

  .cmd-section:last-child {
    margin-bottom: 0;
  }

  .cmd-section-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .cmd-results {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cmd-item {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 12px 16px;
    background: transparent;
    border: none;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-align: left;
    margin-bottom: 4px;
    gap: 12px;
  }

  .cmd-item:hover, .cmd-item:focus, .cmd-item.selected {
    background: rgba(0, 229, 255, 0.05);
    color: var(--text-heading);
    outline: none;
  }

  .cmd-item svg {
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .cmd-item:hover svg, .cmd-item:focus svg {
    color: var(--accent-primary);
  }

  .cmd-shortcut {
    margin-left: auto;
    background: var(--bg-code);
    border: 1px solid var(--border-subtle);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .cmd-footer {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid var(--border-subtle);
    font-size: 11px;
    color: var(--text-muted);
  }

  .cmd-footer kbd {
    background: var(--bg-code);
    border: 1px solid var(--border-subtle);
    padding: 2px 4px;
    border-radius: 4px;
    font-family: var(--font-mono);
  }

  @media (max-width: 600px) {
    .cmd-backdrop {
      padding-top: 0;
    }
    .cmd-modal {
      height: 100%;
      border-radius: 0;
      border: none;
    }
    .cmd-body {
      max-height: calc(100vh - 140px);
    }
  }
</style>
