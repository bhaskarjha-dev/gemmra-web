---
import TerminalDemo from './TerminalDemo.astro';
---

<section class="hero section reveal" id="install">
  <div class="hero-container container">
    
    <div class="hero-content">
      <!-- Badge -->
      <div class="hero-badge reveal delay-100">
        <span class="badge-dot"></span>
        <span class="badge-text">TCS & AMD AI Hackathon 2026</span>
      </div>
      
      <h1 class="hero-title">
        <span class="brand-name accent-text">Gemmra</span>
        <span class="hero-motto">Nidāna for Pharmacovigilance</span>
      </h1>
      
      <p class="hero-subtitle">
        AI-powered drug safety review with auditable reasoning. One fine-tuned model that automates 4 critical pharmacovigilance tasks — from 30 minutes per case to under 10 seconds.
      </p>

      <!-- CTA & Command -->
      <div class="hero-actions reveal delay-300">
        <a href="https://github.com/bhaskarjha-dev/gemmra" target="_blank" rel="noopener" class="btn btn-primary magnetic">
          View on GitHub
          <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a href="https://huggingface.co/Amaltrkmr/gemmra-pv-31b-lora" target="_blank" rel="noopener" class="btn btn-secondary magnetic">
          HuggingFace Model
        </a>
      </div>

      <!-- Stats Grid (Credibility Booster) -->
      <gemmra-stats class="hero-stats reveal delay-300">
        <div class="stat">
          <span class="counter color-tcs" data-target="0.862">0</span>
          <label>Composite Score</label>
        </div>
        <div class="stat">
          <span class="counter color-amd" data-target="0.995">0</span>
          <label>Seriousness F1</label>
        </div>
        <div class="stat">
          <span class="counter color-success" data-target="100">0</span>
          <label>Format Compliance</label>
        </div>
      </gemmra-stats>

      <!-- Trust Badges -->
      <div class="hero-trust reveal delay-300">
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          ICH E2A Compliant
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="15" x2="23" y2="15"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="15" x2="4" y2="15"/></svg>
          AMD MI300X Optimized
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Auditable Reasoning
        </div>
      </div>
    </div>

    <!-- Product As Demo (Shifted Top-Right) -->
    <div class="hero-visual reveal delay-200">
      <div class="mesh-gradient"></div>
      <div class="terminal-glow"></div>
      <!-- Interactive Terminal Setup Demo -->
      <TerminalDemo />
    </div>

  </div>
  
  <!-- Scroll Down Indicator -->
  <div class="scroll-indicator reveal delay-400">
    <div class="mouse-scroll">
      <span class="mouse-wheel"></span>
    </div>
    <span class="scroll-text">Scroll to explore</span>
  </div>
</section>

<script>
  class GemmraStats extends HTMLElement {
    connectedCallback() {
      const counters = this.querySelectorAll('.counter');
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            this.animateCounters(counters);
            observer.disconnect();
          }
        });
      }, { threshold: 0.1 });
      observer.observe(this);
    }

    animateCounters(counters: NodeListOf<Element>) {
      counters.forEach(counterEl => {
        const counter = counterEl as HTMLElement;
        const target = parseFloat(counter.dataset.target || '0');
        const isPercent = target >= 1;
        const duration = 2000;
        const start = performance.now();
        
        function update(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3); // Cubic ease-out
          const current = target * eased;
          
          counter.textContent = isPercent 
            ? Math.round(current) + '%'
            : current.toFixed(3);
            
          if (progress < 1) {
            requestAnimationFrame(update);
          }
        }
        requestAnimationFrame(update);
      });
    }
  }

  if (typeof window !== 'undefined' && !customElements.get('gemmra-stats')) {
    customElements.define('gemmra-stats', GemmraStats);
  }

  // Magnetic Buttons & 3D Magnetic Terminal
  document.addEventListener('astro:page-load', () => {
    // Magnetic Buttons
    const magneticEls = document.querySelectorAll('.magnetic');
    magneticEls.forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.addEventListener('mousemove', (e) => {
        const rect = htmlEl.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        htmlEl.style.transform = `translate(${x * 0.1}px, ${y * 0.1}px)`;
      });
      htmlEl.addEventListener('mouseleave', () => {
        htmlEl.style.transform = 'translate(0px, 0px)';
      });
    });

    const heroVisual = document.querySelector('.hero-visual') as HTMLElement;
    const terminalNode = document.querySelector('gemmra-terminal') as HTMLElement;
    
    if (heroVisual && terminalNode) {
      heroVisual.addEventListener('mousemove', (e) => {
        const rect = heroVisual.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = ((y - centerY) / centerY) * -10;
        const rotateY = ((x - centerX) / centerX) * 10;
        
        terminalNode.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      
      heroVisual.addEventListener('mouseleave', () => {
        terminalNode.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      });
    }
  });
</script>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + var(--space-2xl));
    padding-bottom: var(--space-4xl);
    position: relative;
  }

  /* Fluid Container Architecture */
  .hero-container {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-3xl);
    align-items: start;
    position: relative;
    z-index: 10;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-full);
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-amd-red);
    box-shadow: 0 0 10px var(--accent-amd-red-glow);
    animation: pulse 3s ease-in-out infinite;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .brand-name {
    font-size: clamp(3.2rem, 9vw, 5.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .hero-motto {
    font-size: clamp(1.4rem, 4vw, 2.1rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-top: 6px;
    background: linear-gradient(90deg, var(--text-heading), var(--text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    margin-bottom: var(--space-2xl);
    font-size: var(--text-lg);
    color: #d4d4d8;
    max-width: 95%;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    width: 100%;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--gradient-accent);
    color: #000000;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-weight: 700;
    box-shadow: 0 0 20px var(--accent-glow-strong);
    transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow var(--transition-fast);
  }
  .btn-primary:hover {
    box-shadow: 0 0 30px var(--accent-primary);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-primary);
    border: 1px solid var(--border-card);
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color var(--transition-fast), background var(--transition-fast);
  }
  .btn-secondary:hover {
    border-color: var(--border-accent);
    background: rgba(99, 102, 241, 0.05);
    color: var(--accent-primary);
  }

  /* Stats Grid styling */
  .hero-stats {
    display: flex;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    width: 100%;
  }

  .stat {
    text-align: left;
  }

  .stat .counter {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    display: block;
  }

  .stat .counter.color-amd {
    color: var(--accent-primary);
    text-shadow: 0 0 15px rgba(237, 28, 36, 0.2);
  }

  .stat .counter.color-tcs {
    color: var(--accent-secondary);
    text-shadow: 0 0 15px rgba(15, 98, 254, 0.2);
  }

  .stat .counter.color-success {
    color: var(--color-success);
    text-shadow: 0 0 15px rgba(16, 185, 129, 0.2);
  }

  .stat label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-xs);
    display: block;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
    gap: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    position: relative;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border-subtle);
    overflow: hidden;
  }

  .trust-item::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    transition: left 0.5s ease-in-out;
  }
  .trust-item:hover::after {
    left: 150%;
  }

  .text-success { color: var(--color-success); }
  .text-accent { color: var(--accent-primary); }

  /* Hero Visual - Product as Demo */
  .hero-visual {
    position: relative;
    width: 100%;
    align-self: start;
    margin-top: 0;
    container-type: inline-size;
    perspective: 1000px;
    z-index: 10;
  }

  /* Target the web component for 3D */
  gemmra-terminal {
    display: block;
    transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    transform-style: preserve-3d;
  }

  .mesh-gradient {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate3d(-50%, -50%, 0);
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 20% 30%, rgba(237, 28, 36, 0.06) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(15, 98, 254, 0.06) 0%, transparent 50%);
    filter: blur(60px);
    z-index: -2;
  }

  .terminal-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    aspect-ratio: 1/1;
    background: conic-gradient(from 180deg at 50% 50%, rgba(237, 28, 36, 0) 0deg, rgba(99, 102, 241, 0.08) 180deg, rgba(237, 28, 36, 0) 360deg);
    filter: blur(80px);
    border-radius: 50%;
    z-index: -1;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-content, .hero-visual {
    min-width: 0; /* CRITICAL: Prevents CSS Grid blowout on mobile */
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .hero-container {
      grid-template-columns: minmax(0, 1fr);
      text-align: center;
      gap: var(--space-4xl);
    }
    .hero-content {
      align-items: center;
      text-align: center;
    }
    .hero-subtitle {
      max-width: 100%;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-stats {
      justify-content: center;
      gap: var(--space-xl);
    }
    .stat {
      text-align: center;
    }
    .hero-trust {
      justify-content: center;
    }
  }
  @media (max-width: 600px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-primary {
      justify-content: center;
    }
    .hero-stats {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-md);
    }
  }

  /* CTA Button Arrow Micro-animation */
  .btn-primary:hover .cta-arrow {
    transform: translateX(4px);
  }
  .cta-arrow {
    transition: transform var(--transition-fast);
  }

  /* Scroll Indicator Styling */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-3xl);
    margin-bottom: calc(-1 * var(--space-2xl));
    opacity: 0.5;
    transition: opacity var(--transition-base);
    cursor: pointer;
    z-index: 20;
    position: relative;
    width: 100%;
  }
  .scroll-indicator:hover {
    opacity: 0.95;
  }
  .mouse-scroll {
    width: 20px;
    height: 32px;
    border: 2px solid var(--text-muted);
    border-radius: 12px;
    position: relative;
  }
  .mouse-wheel {
    width: 4px;
    height: 6px;
    background: var(--accent-primary);
    border-radius: 50%;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollWheel 2s ease-in-out infinite;
  }
  .scroll-text {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }
  @keyframes scrollWheel {
    0% { top: 6px; opacity: 1; }
    50% { top: 16px; opacity: 0; }
    100% { top: 6px; opacity: 1; }
  }
</style>
