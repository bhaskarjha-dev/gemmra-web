---
const team = [
  {
    name: 'Amal T R',
    email: 'tr.amal@tcs.com',
    photo: '/Amaltr_pic.png',
    github: 'https://github.com/amaltr',
    hf: 'https://huggingface.co/Amaltrkmr',
  },
  {
    name: 'Bhaskar Jha',
    email: 'b.jha3@tcs.com',
    photo: '/bhaskar_pic.png',
    github: 'https://github.com/bhaskarjha-dev',
    hf: 'https://huggingface.co/bhaskarjha-dev',
  },
];
---

<section class="team-section section reveal" id="team">
  <div class="container">
    <div class="team-header reveal delay-100">
      <div class="hackathon-badge">
        <span class="badge-dot"></span>
        <span>Team 2930 · FINETUNING_005</span>
      </div>
      <h2 class="section-title">Built by <span class="accent-text">Two Engineers.</span></h2>
      <p class="section-subtitle">TCS & AMD AI Hackathon 2026 — Fine-Tuning Track</p>
    </div>

    <div class="team-grid reveal delay-200">
      {team.map((member) => (
        <div class="team-card">
          <div class="member-avatar">
            <img src={member.photo} alt={member.name} class="avatar-img" width="100" height="100" loading="lazy" />
          </div>
          <h3 class="member-name">{member.name}</h3>
          <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
          <div class="member-links">
            <a href={member.github} target="_blank" rel="noopener" class="member-link" aria-label="GitHub">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              <span>GitHub</span>
            </a>
            <a href={member.hf} target="_blank" rel="noopener" class="member-link" aria-label="HuggingFace">
              <span>🤗</span>
              <span>HuggingFace</span>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="hackathon-info reveal delay-300">
      <div class="info-item">
        <span class="info-label">Hackathon</span>
        <span class="info-value">TCS & AMD AI Hackathon 2026</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Team</span>
        <span class="info-value">#2930</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Track</span>
        <span class="info-value">FINETUNING_005</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">Model</span>
        <span class="info-value">Gemma 4 31B (bf16 LoRA)</span>
      </div>
    </div>
  </div>
</section>

<style>
  .team-section {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .team-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-accent), transparent);
  }

  .team-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-3xl) auto;
  }

  .hackathon-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 6px 16px;
    border-radius: var(--radius-full);
    background: rgba(0, 196, 204, 0.06);
    border: 1px solid rgba(0, 196, 204, 0.2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-primary);
    font-weight: 600;
    margin-bottom: var(--space-lg);
    letter-spacing: 0.02em;
  }

  .hackathon-badge .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-primary);
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    max-width: 800px;
    margin: 0 auto var(--space-3xl) auto;
  }

  .team-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    text-align: center;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .team-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top center, rgba(0, 196, 204, 0.03), transparent 70%);
    pointer-events: none;
  }

  .team-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-accent);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 196, 204, 0.05);
  }

  .member-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 2px solid rgba(0, 196, 204, 0.3);
    overflow: hidden;
    margin: 0 auto var(--space-lg) auto;
    background: var(--bg-tertiary);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .member-name {
    font-size: var(--text-xl);
    color: var(--text-heading);
    font-family: var(--font-display);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .member-email {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .member-email:hover {
    color: var(--accent-primary);
  }

  .member-links {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }

  .member-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .member-link:hover {
    color: var(--text-heading);
    border-color: var(--border-accent);
    background: rgba(0, 196, 204, 0.05);
  }

  /* Hackathon Info Bar */
  .hackathon-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    padding: var(--space-lg) var(--space-2xl);
    background: var(--bg-secondary);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-xl);
    max-width: 800px;
    margin: 0 auto;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .info-label {
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
  }

  .info-value {
    font-size: var(--text-sm);
    color: var(--text-heading);
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .info-divider {
    width: 1px;
    height: 32px;
    background: var(--border-subtle);
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
    .hackathon-info {
      flex-wrap: wrap;
      gap: var(--space-md);
    }
    .info-divider {
      display: none;
    }
  }
</style>
