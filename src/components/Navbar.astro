<header class="navbar" id="navbar">
  <div class="nav-container">
    <div class="nav-brand">
      <a href="/">
        <svg class="brand-logo" width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="#00c4cc"/>
          <text x="16" y="22" text-anchor="middle" font-family="system-ui" font-weight="700" font-size="18" fill="white">G</text>
        </svg>
        Gemmra
      </a>
    </div>

    <ul class="nav-links">
      <li><a href="#tasks">Tasks</a></li>
      <li><a href="#architecture">Architecture</a></li>
      <li><a href="#results">Results</a></li>
    </ul>

    <div class="nav-actions">
      <a href="https://github.com/00bjxx/PharmaReview-AI" target="_blank" rel="noopener" class="github-link" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div class="mobile-menu" id="mobile-menu">
    <a href="#tasks">Tasks</a>
    <a href="#architecture">Architecture</a>
    <a href="#results">Results</a>
    <a href="https://github.com/00bjxx/PharmaReview-AI" target="_blank" rel="noopener">GitHub</a>
  </div>
</header>

<script>
  class NavbarManager extends HTMLElement {
    private scrollHandler: () => void;
    private navbar: HTMLElement | null;

    constructor() {
      super();
      this.navbar = document.getElementById('navbar');
      this.scrollHandler = () => {
        if (window.scrollY > 20) {
          this.navbar?.classList.add('scrolled');
        } else {
          this.navbar?.classList.remove('scrolled');
        }
      };
    }

    connectedCallback() {
      window.addEventListener('scroll', this.scrollHandler, { passive: true });
      // Trigger initially in case page loaded scrolled down
      this.scrollHandler();

      const mobileToggle = document.querySelector('.mobile-nav-toggle');
      const mobileMenu = document.getElementById('mobile-menu');

      mobileToggle?.addEventListener('click', () => {
        const isExpanded = mobileToggle.getAttribute('aria-expanded') === 'true';
        mobileToggle.setAttribute('aria-expanded', String(!isExpanded));
        mobileMenu?.classList.toggle('active');
      });
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.scrollHandler);
    }
  }

  if (!customElements.get('navbar-manager')) {
    customElements.define('navbar-manager', NavbarManager);
  }
</script>

<navbar-manager></navbar-manager>

<style>
  .navbar {
    position: fixed;
    top: var(--space-md);
    left: 0;
    right: 0;
    margin-inline: auto;
    width: 90%;
    max-width: var(--max-width);
    height: 60px;
    /* Base Glassmorphism */
    background: rgba(5, 5, 5, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full);
    z-index: 100;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    /* Liquid highlight edge */
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1), 0 10px 30px rgba(0,0,0,0.5);
  }

  .navbar.scrolled {
    width: 80%;
    max-width: calc(var(--max-width) * 0.8);
    top: var(--space-sm);
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.2), 0 20px 40px rgba(0,0,0,0.9), 0 0 20px rgba(0, 229, 255, 0.15);
  }

  .nav-container {
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  .nav-brand a {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-heading);
    font-weight: 700;
    font-size: var(--text-lg);
    letter-spacing: -0.02em;
    position: relative;
  }
  .nav-brand a::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    box-shadow: 0 0 20px var(--accent-glow);
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: -1;
  }
  .nav-brand a:hover::after {
    opacity: 1;
  }

  .brand-logo {
    display: block;
    border-radius: var(--radius-sm);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    list-style: none;
    margin-left: var(--space-xl);
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none !important;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .nav-links a:hover {
    color: var(--text-heading);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-left: auto;
  }



  .github-link {
    display: flex;
    align-items: center;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }
  .github-link:hover {
    color: var(--text-primary);
  }



  /* Mobile Nav Button */
  .mobile-nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: var(--space-xs);
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .nav-actions {
      gap: var(--space-xs);
    }
    
    .navbar, .navbar.scrolled {
      top: 0;
      left: 0;
      right: 0;
      margin-inline: 0;
      width: 100%;
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
    }
    
    .nav-actions .github-link {
      display: none !important;
    }

    .mobile-nav-toggle {
      display: flex !important;
      align-items: center;
      justify-content: center;
      margin-left: 4px;
    }
  }

  /* Mobile Menu Styles */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    padding: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-base), padding var(--transition-base);
  }

  .mobile-menu.active {
    max-height: 300px;
    padding: var(--space-md) 0;
  }

  .mobile-menu a {
    color: var(--text-primary);
    padding: var(--space-md) var(--space-2xl);
    font-size: var(--text-base);
    text-decoration: none;
    font-weight: 500;
    border-left: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .mobile-menu a:hover {
    background: rgba(255, 255, 255, 0.05);
    border-left-color: var(--accent-primary);
    color: var(--text-heading);
  }
</style>
