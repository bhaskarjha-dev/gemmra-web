---
const resultsData = [
  { task: 'T1 Seriousness Classification', metric: 'F1 Score', score: '0.995', samples: '890', status: '✅ Near-perfect', highlightClass: 'success' },
  { task: 'T2 MedDRA Coding', metric: 'Weighted Accuracy', score: '0.667', samples: '890', status: '🔶 Room to grow', highlightClass: 'warning' },
  { task: 'T3 Labelling Assessment', metric: 'F1 Score', score: '0.801', samples: '890', status: '✅ Strong', highlightClass: 'strong' },
  { task: 'T4 WHO-UMC Causality', metric: 'Weighted Accuracy', score: '0.986', samples: '890', status: '✅ Near-perfect', highlightClass: 'success' },
  { task: 'Format Compliance', metric: 'All tasks', score: '100%', samples: '3,560', status: '✅ Perfect', highlightClass: 'perfect' },
  { task: 'Composite Score', metric: 'Average', score: '0.862', samples: '3,560', status: '✅ Shipped', highlightClass: 'composite' }
];
---

<section class="comparison section" id="results">
  <div class="container">
    <h2 class="section-title">How <span class="accent-text">Gemmra</span> performs.</h2>
    <p class="section-subtitle">Evaluated on 3,560 decontaminated samples across 4 pharmacovigilance tasks. Full bf16 inference on AMD MI300X.</p>

    <div class="table-container">
      <table class="compare-table">
        <thead>
          <tr>
            <th class="task-col">Task</th>
            <th>Metric</th>
            <th>Score</th>
            <th>Samples</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {resultsData.map((row) => (
            <tr class={`table-row ${row.highlightClass}-row`}>
              <td class="task-cell">{row.task}</td>
              <td>{row.metric}</td>
              <td class={`score-cell ${row.highlightClass}`}>
                <span>{row.score}</span>
              </td>
              <td class="samples-cell">{row.samples}</td>
              <td class="status-cell">{row.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    background: var(--bg-secondary);
  }

  .table-container {
    width: 100%;
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-card);
    background: rgba(3, 3, 8, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-card);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
    white-space: nowrap;
  }

  .compare-table th {
    padding: var(--space-lg) var(--space-md);
    font-weight: 600;
    color: var(--text-heading);
    border-bottom: 1px solid var(--border-card);
    background: var(--bg-tertiary);
    font-family: var(--font-display);
    font-size: var(--text-sm);
  }

  .compare-table td {
    padding: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .compare-table tr:last-child td {
    border-bottom: none;
  }

  .compare-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.01);
  }

  .task-col, .task-cell {
    text-align: left;
    position: sticky;
    left: 0;
    background: var(--bg-primary);
    z-index: 10;
  }

  .compare-table th.task-col {
    background: var(--bg-tertiary);
  }

  .compare-table tbody tr:hover .task-cell {
    background: var(--bg-tertiary);
  }

  .task-cell {
    font-weight: 500;
    color: var(--text-primary);
    border-left: 3px solid transparent;
    transition: all var(--transition-fast);
  }

  .success-row .task-cell, .perfect-row .task-cell {
    border-left-color: var(--color-success);
  }

  .warning-row .task-cell {
    border-left-color: var(--color-warning);
  }

  .composite-row-custom .task-cell, .composite-row .task-cell {
    border-left-color: var(--accent-secondary);
  }

  .table-row:hover .task-cell {
    padding-left: calc(var(--space-md) + 2px);
    border-left-width: 6px;
  }

  .samples-cell {
    font-family: var(--font-mono);
  }

  .score-cell {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .score-cell.success {
    color: var(--color-success);
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.2);
  }

  .score-cell.warning {
    color: var(--color-warning);
    text-shadow: 0 0 10px rgba(245, 158, 11, 0.2);
  }

  .score-cell.strong {
    color: var(--text-primary);
  }

  .score-cell.perfect {
    color: var(--color-success);
  }

  .score-cell.composite {
    color: var(--accent-primary);
    font-size: var(--text-lg);
    text-shadow: 0 0 12px var(--accent-glow-strong);
  }

  .composite-row {
    background: rgba(15, 98, 254, 0.03) !important;
    border-top: 1px solid var(--border-accent);
    border-bottom: 1px solid var(--border-accent);
  }

  .composite-row td {
    color: var(--text-heading) !important;
    font-weight: 700;
  }

  .composite-row .task-cell, .composite-row .score-cell {
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .compare-table th, .compare-table td {
      padding: var(--space-sm) var(--space-md);
    }
  }
</style>
