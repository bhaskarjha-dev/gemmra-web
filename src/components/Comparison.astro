---
const resultsData = [
  { task: 'T1 Seriousness', metric: 'F1 Score', base: '0.840', gemmra: '0.995', improvement: '+18.5%', samples: '1,027', status: '✅ Near-perfect', highlightClass: 'success' },
  { task: 'T2 MedDRA Coding', metric: 'Weighted', base: '0.080', gemmra: '0.667', improvement: '+733%', samples: '759', status: '🔶 Room to grow', highlightClass: 'warning' },
  { task: 'T3 Labelling', metric: 'F1 Score', base: '0.720', gemmra: '0.801', improvement: '+11.3%', samples: '980', status: '✅ Strong', highlightClass: 'strong' },
  { task: 'T4 Causality', metric: 'Weighted', base: '0.420', gemmra: '0.986', improvement: '+135%', samples: '794', status: '✅ Near-perfect', highlightClass: 'success' },
];
---

<section class="comparison section" id="results">
  <div class="container">
    <h2 class="section-title">Base model vs. <span class="accent-text">Gemmra.</span></h2>
    <p class="section-subtitle">Same model, same hardware. The difference is data-first fine-tuning and iterative debugging.<br/>Evaluated on 3,645 decontaminated samples across 4 pharmacovigilance tasks.</p>

    <div class="table-container">
      <table class="compare-table">
        <thead>
          <tr>
            <th class="task-col">Task</th>
            <th>Metric</th>
            <th class="base-col">Base Gemma 4</th>
            <th class="gemmra-col">Gemmra (SFT)</th>
            <th class="improvement-col">Improvement</th>
            <th>Samples</th>
          </tr>
        </thead>
        <tbody>
          {resultsData.map((row) => (
            <tr class={`table-row ${row.highlightClass}-row`}>
              <td class="task-cell">{row.task}</td>
              <td>{row.metric}</td>
              <td class="base-score">{row.base}</td>
              <td class={`score-cell ${row.highlightClass}`}>
                <span>{row.gemmra}</span>
              </td>
              <td class="improvement-cell">{row.improvement}</td>
              <td class="samples-cell">{row.samples}</td>
            </tr>
          ))}
          <!-- Composite Row -->
          <tr class="composite-row">
            <td class="task-cell">Composite Score</td>
            <td>Average</td>
            <td class="base-score">0.515</td>
            <td class="score-cell composite">
              <span>0.862</span>
            </td>
            <td class="improvement-cell composite-improvement">+67.4%</td>
            <td class="samples-cell">3,645</td>
          </tr>
          <!-- Format Row -->
          <tr class="table-row perfect-row">
            <td class="task-cell">Format Compliance</td>
            <td>All tasks</td>
            <td class="base-score base-fail">0%</td>
            <td class="score-cell perfect">
              <span>100%</span>
            </td>
            <td class="improvement-cell">∞</td>
            <td class="samples-cell">3,645</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Insight callout -->
    <div class="insight-callout reveal delay-200">
      <div class="insight-icon">💡</div>
      <div class="insight-text">
        <strong>Key finding:</strong> The biggest gain — T2 MedDRA at <span class="accent-text">+733%</span> — came from fixing a single line in the data pipeline, not from model architecture changes. Data quality beats model tuning.
      </div>
    </div>
  </div>
</section>

<style>
  .comparison {
    background: var(--bg-secondary);
  }

  .table-container {
    width: 100%;
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-card);
    background: rgba(3, 3, 8, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-card);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
    white-space: nowrap;
  }

  .compare-table th {
    padding: var(--space-lg) var(--space-md);
    font-weight: 600;
    color: var(--text-heading);
    border-bottom: 1px solid var(--border-card);
    background: var(--bg-tertiary);
    font-family: var(--font-display);
    font-size: var(--text-sm);
  }

  .compare-table td {
    padding: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .compare-table tr:last-child td {
    border-bottom: none;
  }

  .compare-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.01);
  }

  .task-col, .task-cell {
    text-align: left;
    position: sticky;
    left: 0;
    background: var(--bg-primary);
    z-index: 10;
  }

  .compare-table th.task-col {
    background: var(--bg-tertiary);
  }

  .compare-table tbody tr:hover .task-cell {
    background: var(--bg-tertiary);
  }

  .task-cell {
    font-weight: 500;
    color: var(--text-primary);
    border-left: 3px solid transparent;
    transition: all var(--transition-fast);
  }

  .success-row .task-cell, .perfect-row .task-cell {
    border-left-color: var(--color-success);
  }

  .warning-row .task-cell {
    border-left-color: var(--color-warning);
  }

  .composite-row .task-cell {
    border-left-color: var(--accent-secondary);
  }

  .table-row:hover .task-cell {
    padding-left: calc(var(--space-md) + 2px);
    border-left-width: 6px;
  }

  .samples-cell {
    font-family: var(--font-mono);
  }

  .score-cell {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .score-cell.success {
    color: var(--color-success);
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.2);
  }

  .score-cell.warning {
    color: var(--color-warning);
    text-shadow: 0 0 10px rgba(245, 158, 11, 0.2);
  }

  .score-cell.strong {
    color: var(--text-primary);
  }

  .score-cell.perfect {
    color: var(--color-success);
  }

  .score-cell.composite {
    color: var(--accent-primary);
    font-size: var(--text-lg);
    text-shadow: 0 0 12px var(--accent-glow-strong);
  }

  /* Base model scores — dimmed to contrast with Gemmra */
  .base-score {
    font-family: var(--font-mono);
    color: var(--text-muted);
    opacity: 0.6;
  }

  .base-fail {
    color: var(--color-error);
    opacity: 0.8;
  }

  .base-col {
    color: var(--text-muted);
  }

  .gemmra-col {
    color: var(--accent-primary);
  }

  .improvement-col {
    color: var(--color-success);
  }

  /* Improvement column — green with glow */
  .improvement-cell {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-success);
    text-shadow: 0 0 8px rgba(16, 185, 129, 0.3);
  }

  .composite-improvement {
    color: var(--accent-primary);
    font-size: var(--text-base);
    text-shadow: 0 0 12px var(--accent-glow-strong);
  }

  .composite-row {
    background: rgba(15, 98, 254, 0.03) !important;
    border-top: 1px solid var(--border-accent);
    border-bottom: 1px solid var(--border-accent);
  }

  .composite-row td {
    color: var(--text-heading) !important;
    font-weight: 700;
  }

  .composite-row .task-cell, .composite-row .score-cell {
    font-weight: 700;
  }

  .composite-row .base-score {
    opacity: 0.8;
    color: var(--text-secondary);
  }

  /* Insight Callout */
  .insight-callout {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(0, 196, 204, 0.03);
    border: 1px solid rgba(0, 196, 204, 0.15);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .insight-icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .insight-text strong {
    color: var(--text-heading);
  }

  @media (max-width: 768px) {
    .compare-table th, .compare-table td {
      padding: var(--space-sm) var(--space-md);
    }
  }
</style>
