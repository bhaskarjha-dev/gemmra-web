---
---

<visual-capabilities>
<section class="capabilities-section section reveal" id="capabilities">
  <div class="capabilities-container container">
    <div class="capabilities-header reveal delay-100">
      <h2 class="section-title">Visualizing <span class="accent-text">Zero-Trust</span></h2>
      <p class="section-subtitle">How GitSetu cryptographically separates your identities without relying on fragile global state.</p>
    </div>

    <div class="visualizer-stage reveal delay-200">
      
      <!-- Central Hub / Core Engine -->
      <div class="core-node">
        <div class="pulse-ring"></div>
        <div class="node-inner">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span>GitSetu</span>
        </div>
      </div>

      <!-- Connection Lines -->
      <svg class="connection-lines" width="100%" height="100%">
        <!-- Work Path -->
        <path id="work-line" class="line-path work-path" d="" />
        <!-- Personal Path -->
        <path id="personal-line" class="line-path personal-path" d="" />
      </svg>
      
      <!-- Data Orbs -->
      <div class="data-orb work-orb"></div>
      <div class="data-orb personal-orb"></div>

      <!-- Work Environment Node -->
      <div class="env-node work-node">
        <div class="env-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          <span>~/work/acme</span>
        </div>
        <div class="env-body">
          <div class="config-item active">
            <span class="label">Key:</span>
            <span class="value">ed25519-sk (YubiKey)</span>
          </div>
          <div class="config-item active">
            <span class="label">Email:</span>
            <span class="value">eng@acme.corp</span>
          </div>
        </div>
        <div class="boundary-shield"></div>
      </div>

      <!-- Personal Environment Node -->
      <div class="env-node personal-node">
        <div class="env-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span>~/projects/oss</span>
        </div>
        <div class="env-body">
          <div class="config-item">
            <span class="label">Key:</span>
            <span class="value">id_rsa_github</span>
          </div>
          <div class="config-item">
            <span class="label">Email:</span>
            <span class="value">me@bhaskarjha.dev</span>
          </div>
        </div>
        <div class="boundary-shield"></div>
      </div>

    </div>
  </div>
</section>
</visual-capabilities>

<style>
  .capabilities-container {
    width: 100%;
  }

  .visualizer-stage {
    position: relative;
    width: 100%;
    min-height: 500px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 0 100px rgba(0, 229, 255, 0.02);
  }

  /* Grid Background */
  .visualizer-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: center;
    z-index: 0;
    opacity: 0.5;
  }

  /* Central Core Engine Node */
  .core-node {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  .node-inner {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-accent);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    box-shadow: 0 0 30px var(--accent-glow-strong);
    position: relative;
    z-index: 2;
  }

  .pulse-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    border-radius: var(--radius-full);
    border: 2px solid var(--accent-primary);
    animation: ping 3s cubic-bezier(0, 0, 0.2, 1) infinite;
    z-index: 1;
    opacity: 0.5;
  }

  /* SVG Connection Lines */
  .connection-lines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .line-path {
    fill: none;
    stroke: var(--border-subtle);
    stroke-width: 2;
  }

  .work-path {
    stroke: rgba(0, 229, 255, 0.2);
  }

  /* Data Orbs */
  .data-orb {
    position: absolute;
    top: 0; left: 0;
    width: 12px; height: 12px;
    border-radius: 50%;
    offset-distance: 0%;
    z-index: 4; /* Travels UNDER the env-nodes for 3D depth */
  }
  .work-orb {
    background: var(--accent-primary);
    box-shadow: 0 0 15px var(--accent-primary), 0 0 30px var(--accent-primary);
    offset-path: var(--work-path);
    animation: flowOrb 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .personal-orb {
    background: var(--text-secondary);
    box-shadow: 0 0 15px var(--text-secondary);
    offset-path: var(--personal-path);
    animation: flowOrb 2.5s cubic-bezier(0.4, 0, 0.2, 1) infinite 1.25s;
  }
  @keyframes flowOrb {
    0% { offset-distance: 0%; opacity: 0; transform: scale(0.5); }
    10% { opacity: 1; transform: scale(1); }
    90% { opacity: 1; transform: scale(1); }
    100% { offset-distance: 100%; opacity: 0; transform: scale(2); }
  }

  /* Environment Nodes */
  .env-node {
    position: absolute;
    width: 280px;
    background: var(--bg-code);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    z-index: 5;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .env-node:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6);
  }

  /* Node Heartbeat */
  @keyframes nodeHeartbeat {
    0%, 90% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.05); }
    95% { box-shadow: 0 0 40px rgba(0, 229, 255, 0.4), inset 0 0 20px rgba(0, 229, 255, 0.2); border-color: rgba(0, 229, 255, 0.8); }
    100% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.05); }
  }

  .work-node {
    top: 20%;
    left: 10%;
    border-color: rgba(0, 229, 255, 0.4);
    animation: nodeHeartbeat 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .personal-node {
    bottom: 20%;
    right: 10%;
    border-color: rgba(255, 255, 255, 0.1);
    animation: personalHeartbeat 2.5s cubic-bezier(0.4, 0, 0.2, 1) infinite 1.25s;
    opacity: 0.85;
  }

  @keyframes personalHeartbeat {
    0%, 90% { box-shadow: 0 0 20px rgba(255, 255, 255, 0.02); }
    95% { box-shadow: 0 0 40px rgba(255, 255, 255, 0.15), inset 0 0 20px rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.3); }
    100% { box-shadow: 0 0 20px rgba(255, 255, 255, 0.02); }
  }

  .env-header {
    background: rgba(255, 255, 255, 0.02);
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--text-heading);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .env-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .config-item {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: 6px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    border: 1px solid var(--border-subtle);
  }

  .config-item.active {
    border-color: rgba(0, 229, 255, 0.3);
    color: var(--accent-primary);
  }

  .label { color: var(--text-muted); }
  .value { color: var(--text-secondary); }
  .active .value { color: var(--accent-primary); }

  .boundary-shield {
    position: absolute;
    inset: -10px;
    border: 1px dashed var(--border-subtle);
    border-radius: calc(var(--radius-lg) + 10px);
    pointer-events: none;
    z-index: -1;
  }

  .work-node .boundary-shield {
    border-color: rgba(0, 229, 255, 0.2);
    background: rgba(0, 229, 255, 0.02);
  }

  @keyframes ping {
    75%, 100% {
      transform: translate(-50%, -50%) scale(2);
      opacity: 0;
    }
  }

  @keyframes dashFlow {
    to { stroke-dashoffset: -1000; }
  }

  /* Responsive Media Layout */
  @media (max-width: 800px) {
    .visualizer-stage {
      flex-direction: column;
      height: auto;
      min-height: auto;
      padding: var(--space-4xl) var(--space-md);
      gap: var(--space-3xl);
    }

    .core-node, .env-node {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      bottom: auto;
      transform: none;
    }

    .connection-lines {
      opacity: 0.6; /* Ensure lines are visible on mobile to guide the orbs */
    }

    .env-node {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>

<script>
  class VisualCapabilities extends HTMLElement {
    private resizeObserver: ResizeObserver | null = null;

    connectedCallback() {
      const stage = this.querySelector('.visualizer-stage');
      if (!stage) return;
      
      // Native ResizeObserver guarantees CSS is fully painted and dimensions are accurate
      this.resizeObserver = new ResizeObserver(() => this.drawLines());
      this.resizeObserver.observe(stage);
    }

    disconnectedCallback() {
      if (this.resizeObserver) {
        this.resizeObserver.disconnect();
        this.resizeObserver = null;
      }
    }

    drawLines() {
      const core = this.querySelector('.core-node');
      const work = this.querySelector('.work-node');
      const personal = this.querySelector('.personal-node');
      const svg = this.querySelector('.connection-lines');
      const workPath = this.querySelector('.work-path');
      const personalPath = this.querySelector('.personal-path');
      
      if (!core || !work || !personal || !svg || !workPath || !personalPath) return;

      const svgRect = svg.getBoundingClientRect();
      const cRect = core.getBoundingClientRect();
      const wRect = work.getBoundingClientRect();
      const pRect = personal.getBoundingClientRect();

      // Center coordinates relative to SVG
      const cx = cRect.left + cRect.width / 2 - svgRect.left;
      const cy = cRect.top + cRect.height / 2 - svgRect.top;
      
      const wx = wRect.left + wRect.width / 2 - svgRect.left;
      const wy = wRect.top + wRect.height / 2 - svgRect.top;
      
      const px = pRect.left + pRect.width / 2 - svgRect.left;
      const py = pRect.top + pRect.height / 2 - svgRect.top;

      const isMobile = window.innerWidth <= 800;

      if (isMobile) {
        // 2-lane data bus vertical flow for mobile
        const laneOffset = 15;
        
        const wPathStr = `M ${cx - laneOffset} ${cy} L ${wx - laneOffset} ${wy}`;
        const pPathStr = `M ${cx + laneOffset} ${cy} L ${px + laneOffset} ${py}`;
        
        workPath.setAttribute('d', wPathStr);
        personalPath.setAttribute('d', pPathStr);
        
        document.documentElement.style.setProperty('--work-path', `path('${wPathStr}')`);
        document.documentElement.style.setProperty('--personal-path', `path('${pPathStr}')`);
      } else {
        // Curved desktop paths
        const wPathStr = `M ${cx} ${cy} C ${cx} ${wy}, ${wx} ${cy}, ${wx} ${wy}`;
        const pPathStr = `M ${cx} ${cy} C ${cx} ${py}, ${px} ${cy}, ${px} ${py}`;
        
        workPath.setAttribute('d', wPathStr);
        personalPath.setAttribute('d', pPathStr);
        
        document.documentElement.style.setProperty('--work-path', `path('${wPathStr}')`);
        document.documentElement.style.setProperty('--personal-path', `path('${pPathStr}')`);
      }
    }
  }

  if (typeof window !== 'undefined' && !customElements.get('visual-capabilities')) {
    customElements.define('visual-capabilities', VisualCapabilities);
  }
</script>
