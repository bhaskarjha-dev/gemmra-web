---
---

<gemmra-cta>
<section class="cta-section section reveal">
  <div class="event-horizon-container">
    <div class="event-horizon"></div>
    <div class="event-horizon-core"></div>
  </div>
  
  <div class="cta-container container">
    <div class="cta-content">
      <h2 class="cta-title">Explore <span class="accent-text glow-title">Gemmra.</span></h2>
      <p class="cta-subtitle">Fine-tuned Gemma 4 31B for pharmacovigilance. Open source. Built on AMD MI300X.</p>
      
      <div class="cta-actions">
        <a href="https://github.com/bhaskarjha-dev/gemmra" target="_blank" rel="noopener" class="btn btn-primary">
          View on GitHub →
        </a>
        <a href="https://huggingface.co/team-gemmra/gemmra" target="_blank" rel="noopener" class="btn btn-outline">
          Model on HuggingFace →
        </a>
      </div>
    </div>
  </div>
</section>
</gemmra-cta>

<script>
  class GemmraCta extends HTMLElement {
    connectedCallback() {
      const ctaSection = this.querySelector('.cta-section') as HTMLElement;
      if (ctaSection) {
        ctaSection.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = ctaSection.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          ctaSection.style.setProperty('--mouse-x', `${x}%`);
        });
      }
    }
  }

  if (typeof window !== 'undefined' && !customElements.get('gemmra-cta')) {
    customElements.define('gemmra-cta', GemmraCta);
  }
</script>

<style>
  .cta-section {
    position: relative;
    padding-top: var(--space-4xl);
    padding-bottom: 150px;
    margin-top: var(--space-2xl);
    overflow: hidden;
    --mouse-x: 50%;
  }

  .event-horizon-container {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 150vw;
    height: 400px;
    z-index: 0;
    pointer-events: none;
    display: flex;
    justify-content: center;
  }

  .event-horizon {
    position: absolute;
    top: 50px;
    width: 100%;
    height: 100%;
    border-radius: 100% 100% 0 0;
    background: radial-gradient(ellipse at top center, rgba(237, 28, 36, 0.06) 0%, transparent 60%);
    border-top: 1px solid rgba(237, 28, 36, 0.2);
    box-shadow: inset 0 20px 60px rgba(237, 28, 36, 0.03), 0 -20px 60px rgba(99, 102, 241, 0.1);
    transition: background 0.3s ease;
  }

  .event-horizon-core {
    position: absolute;
    top: 50px;
    width: 60%;
    height: 100%;
    border-radius: 100% 100% 0 0;
    background: radial-gradient(ellipse at top var(--mouse-x), rgba(99, 102, 241, 0.12) 0%, transparent 50%);
    filter: blur(20px);
    mix-blend-mode: screen;
  }

  .cta-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: var(--space-md);
    letter-spacing: -0.04em;
    line-height: 1.1;
  }
  
  .glow-title {
    text-shadow: 0 0 40px rgba(237, 28, 36, 0.4);
  }

  .cta-subtitle {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    margin-bottom: var(--space-3xl);
    max-width: 600px;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: var(--radius-full);
    font-size: var(--text-lg);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: #000000;
    box-shadow: 0 0 20px rgba(0, 196, 204, 0.4);
  }

  .btn-primary:hover {
    box-shadow: 0 0 40px rgba(0, 196, 204, 0.6);
    transform: translateY(-2px);
  }

  .btn-outline {
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
  }

  .btn-outline:hover {
    border-color: rgba(0, 196, 204, 0.5);
    color: var(--accent-primary);
    background: rgba(0, 196, 204, 0.05);
    box-shadow: 0 0 20px rgba(0, 196, 204, 0.1);
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .cta-actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
    .btn {
      width: 100%;
      justify-content: center;
    }
    .event-horizon-container {
      width: 200vw;
    }
  }
</style>
