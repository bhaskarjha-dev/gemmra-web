---
const milestones = [
  {
    version: 'v1',
    label: 'Baseline',
    composite: '0.620',
    insight: 'First SFT checkpoint (0.23 epoch). T1/T4 already strong — model gets seriousness and causality right early.',
    change: 'Initial training',
    highlight: false,
    taskScores: { t1: '1.000', t2: '0.134', t3: '0.387', t4: '0.960' },
  },
  {
    version: 'v5',
    label: 'BioDEX Fix',
    composite: '0.705',
    insight: 'Found abstract[:500] truncation hiding ground truth from 92% of T2 training data. One line fix → T2 jumped 3.9×.',
    change: '+3.9× T2',
    highlight: true,
    taskScores: { t1: '1.000', t2: '0.558', t3: '0.286', t4: '0.975' },
  },
  {
    version: 'v6',
    label: 'Label Balance',
    composite: '0.859',
    insight: 'Forensic audit found 62% NO / 38% YES label imbalance in T3. Rebalancing to 50:50 restored T3 from 0.286 to 0.884.',
    change: '+3× T3',
    highlight: true,
    taskScores: { t1: '1.000', t2: '0.572', t3: '0.884', t4: '0.980' },
  },
  {
    version: 'Final',
    label: 'Full Eval',
    composite: '0.862',
    insight: 'Validated across 3,645 decontaminated samples. T2 improved further at scale (0.572→0.667). Composite confirmed at 0.862.',
    change: 'Shipped ✓',
    highlight: false,
    taskScores: { t1: '0.995', t2: '0.667', t3: '0.801', t4: '0.986' },
  },
];
---

<section class="score-journey section" id="journey">
  <div class="container">
    <h2 class="section-title">The <span class="accent-text">data-first</span> debugging journey.</h2>
    <p class="section-subtitle">We never changed the model architecture. Every improvement came from fixing the training data.</p>

    <div class="timeline">
      <div class="timeline-line"></div>
      {milestones.map((m, i) => (
        <div class={`milestone reveal delay-${(i + 1) * 100} ${m.highlight ? 'milestone-highlight' : ''}`}>
          <div class="milestone-marker">
            <div class="marker-dot"></div>
            {m.highlight && <div class="marker-pulse"></div>}
          </div>
          <div class="milestone-card">
            <div class="milestone-header">
              <span class="version-badge">{m.version}</span>
              <span class="change-badge">{m.change}</span>
            </div>
            <div class="milestone-composite">
              <span class="composite-label">Composite</span>
              <span class="composite-value">{m.composite}</span>
            </div>
            <p class="milestone-insight">{m.insight}</p>
            <div class="task-scores-mini">
              <span class="mini-score" title="T1 Seriousness">T1: {m.taskScores.t1}</span>
              <span class="mini-score" title="T2 MedDRA">T2: {m.taskScores.t2}</span>
              <span class="mini-score" title="T3 Labelling">T3: {m.taskScores.t3}</span>
              <span class="mini-score" title="T4 Causality">T4: {m.taskScores.t4}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .score-journey {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .score-journey::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-accent), transparent);
  }

  .timeline {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-3xl);
  }

  .timeline-line {
    position: absolute;
    top: 28px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, 
      var(--border-subtle) 0%, 
      var(--accent-primary) 35%, 
      var(--accent-primary) 65%, 
      var(--border-accent) 100%
    );
    z-index: 0;
  }

  .milestone {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .milestone-marker {
    position: relative;
    margin-bottom: var(--space-xl);
  }

  .marker-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    border: 2px solid var(--border-card);
    transition: all var(--transition-base);
  }

  .milestone-highlight .marker-dot {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    box-shadow: 0 0 16px var(--accent-glow-strong);
  }

  .marker-pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--accent-primary);
    opacity: 0.4;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
    100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }
  }

  .milestone-card {
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .milestone-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    border-color: var(--border-accent);
  }

  .milestone-highlight .milestone-card {
    border-color: rgba(0, 196, 204, 0.3);
    background: rgba(0, 196, 204, 0.02);
  }

  .milestone-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .version-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-weight: 600;
  }

  .change-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    color: var(--color-success);
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.2);
    font-weight: 600;
  }

  .milestone-highlight .change-badge {
    color: var(--accent-primary);
    background: rgba(0, 196, 204, 0.08);
    border-color: rgba(0, 196, 204, 0.3);
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .milestone-composite {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-md);
  }

  .composite-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .composite-value {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-heading);
    letter-spacing: -0.02em;
  }

  .milestone-highlight .composite-value {
    background: var(--gradient-accent-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .milestone-insight {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    min-height: 60px;
  }

  .task-scores-mini {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .mini-score {
    padding: 2px 6px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    text-align: center;
  }

  @media (max-width: 900px) {
    .timeline {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    .timeline-line {
      display: none;
    }
    .milestone-marker {
      display: none;
    }
    .milestone-insight {
      min-height: auto;
    }
  }
</style>
